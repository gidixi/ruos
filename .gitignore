# Rust OS build artifacts
/build/
/kernel/target/
/user/target/
/tools/*/target/
/third_party/limine/

# Debug / diagnostic debris
*.log
*.ppm
*.png

# Generated wasm artifacts (rebuilt by `make` from sources in user/ and tools/)
user-bin/*.wasm
kernel/src/wasm/wt/*.cwasm

# Editor / IDE
.vscode/
.claude/

# Prebuilt app drop folder: keep README + .gitkeep, ignore the dropped .cwasm
# (auto-bundled into the ISO /bin by the Makefile glob hook).
/apps/*.cwasm

# OS / misc
.DS_Store
Thumbs.db
