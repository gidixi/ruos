# Rust OS build artifacts
/build/
/kernel/target/
/user/target/
/tools/*/target/
/third_party/limine/

# Debug / diagnostic debris
*.log
*.ppm
*.png

# Generated wasm artifacts (rebuilt by `make` from sources in user/ and tools/)
user-bin/*.wasm
kernel/src/wasm/wt/*.cwasm

# Editor / IDE
.vscode/
.claude/

# Prebuilt app drop folder: keep README + .gitkeep, ignore the dropped .cwasm
# (auto-bundled into the ISO /bin by the Makefile glob hook).
/apps/*.cwasm

# Demo/skeleton app SDK (separate repo-in-waiting; builds .cwasm apps without
# touching the OS sources — apps land in apps/ via its deploy script).
/demo-apps-sdk/

# OS / misc
.DS_Store
Thumbs.db
