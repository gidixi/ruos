# Rust OS build artifacts
/build/
/kernel/target/
/user/target/
/tools/*/target/
/third_party/limine/

# Debug / diagnostic debris
*.log
*.ppm
*.png

# Generated wasm artifacts (rebuilt by `make` from sources in user/ and tools/)
user-bin/*.wasm
kernel/src/wasm/wt/*.cwasm
# Exception: lua.wasm is third-party C (no in-repo source), built once with
# wasi-sdk via third_party/lua/build-wasm.sh and committed as a vendored prebuilt.
!user-bin/lua.wasm

# third_party/lua: keep only the build script + README; ignore the downloaded
# Lua source tree / tarball (re-fetched by build-wasm.sh).
/third_party/lua/*
!/third_party/lua/build-wasm.sh
!/third_party/lua/README.md

# Editor / IDE
.vscode/
.claude/

# Prebuilt app drop folder: keep README + .gitkeep, ignore the dropped .cwasm
# (auto-bundled into the ISO /bin by the Makefile glob hook).
/apps/*.cwasm

# OS / misc
.DS_Store
Thumbs.db
